{
  "name": "gha-linter-lite",
  "version": "0.1.1",
  "description": "Small GitHub Actions workflow linter for maintainers.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "gha-linter-lite": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && ncc build dist/cli.js -o dist-action --target es2022",
    "lint": "eslint .",
    "test": "vitest run",
    "check": "npm run lint && npm test && npm run build"
  },
  "keywords": [
    "github-actions",
    "workflow",
    "linter",
    "ci",
    "oss"
  ],
  "author": "Heart619",
  "license": "MIT",
  "type": "commonjs",
  "files": [
    "dist",
    "dist-action",
    "action.yml",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^10.4.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
